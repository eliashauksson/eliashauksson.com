# Local development email settings.
# Copy this file to .env and fill MAIL_PASSWORD with a Proton SMTP token.
# Do not commit .env.

SECRET_KEY=

MAIL_SERVER=smtp.protonmail.ch
MAIL_PORT=587

MAIL_USERNAME=contact@eliashauksson.com
MAIL_PASSWORD=

MAIL_USE_TLS=1
MAIL_USE_SSL=0

MAIL_DEFAULT_SENDER=contact@eliashauksson.com
MAIL_RECIPIENT=contact@eliashauksson.com
